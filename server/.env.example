# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control!

PORT=7100
MONGODB_URI=mongodb+srv://YOUR_MONGO_USER:YOUR_MONGO_PASSWORD@YOUR_CLUSTER.mongodb.net/YOUR_DATABASE_NAME
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

JWT_SECRET=YOUR_SECURE_JWT_SECRET_HERE_MIN_32_CHARS
JWT_EXPIRES_IN=1h

SMTP_USER=YOUR_GMAIL_OR_EMAIL@gmail.com
SMTP_PASS=YOUR_APP_SPECIFIC_PASSWORD_NOT_ACTUAL_PASSWORD

# Optional: Restrict CORS to specific origins (comma-separated)
# CORS_ORIGIN=http://localhost:3000,https://yourdomain.com
